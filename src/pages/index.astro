---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { metadata as pageMetadata } from "@/components/pages/home/Page.js";
import Hero from "@/components/home/hero";
import About from "@/components/home/about";
import Skills from "@/components/home/skills";
import Works from "@/components/home/works";
import Testimonials from "@/components/home/testimonials";
import WhatWeOffer from "@/components/home/whatweoffer";
import WhyChooseMe from "@/components/home/WhyChooseMe";

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  serviceType: "Web Development and Mobile App Development",
  provider: {
    "@type": "Person",
    name: "Anagh K R"
  },
  areaServed: {
    "@type": "State",
    name: "Kerala"
  },
  description:
    "Professional web development and mobile app development services in Kerala including Flutter app development, MERN stack development, responsive web design.",
  offers: {
    "@type": "Offer",
    priceSpecification: {
      "@type": "PriceSpecification",
      priceCurrency: "INR"
    }
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "How do I choose the best freelance website developer in Kerala?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "When hiring a freelance website developer in Kerala, look for proof of performance, local project delivery, deep expertise in React/Node, and reliable post-launch support. ANAGH K R provides premium custom websites and Flutter apps across Kochi, Calicut, and Trivandrum with transparent, milestone-based timelines."
      }
    },
    {
      "@type": "Question",
      name: "What web design and website development services do you offer in Kerala?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "As a leading freelance website developer in Kerala, ANAGH K R offers full-service web solutions including custom MERN stack development, responsive design, web applications, performance-focused website redesigns, search engine optimization (SEO), and custom Flutter mobile app development."
      }
    },
    {
      "@type": "Question",
      name: "Why hire a freelance website developer in Kerala over an agency?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Hiring a freelance website developer in Kerala offers direct communication, faster execution, custom design flexibility, and cost-effective pricing. You work directly with the expert engineer executing your code, ensuring maximum transparency, responsive layouts, and dedicated post-launch maintenance without agency overheads."
      }
    }
  ]
};
---

<BaseLayout metadata={pageMetadata}>
  <script type="application/ld+json" set:html={JSON.stringify(serviceSchema)}></script>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)}></script>

  <Hero />
  <About client:visible />
  <Skills client:visible />
  <Works client:visible />
  <Testimonials client:visible />
  <WhatWeOffer client:visible />
  <WhyChooseMe client:visible />
</BaseLayout>
