---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getBlogPosts } from "@/lib/blog";
import { marked } from "marked";

function autoLinkPlainUrls(content) {
  return String(content || "")
    .split("\n")
    .map((line) => {
      if (/\[[^\]]+\]\([^\)]+\)/.test(line)) {
        return line;
      }

      return line
        .replace(/(^|[\s(])((https?:\/\/[^\s<)]+))/gi, "$1[$2]($2)")
        .replace(/(^|[\s(])(www\.[^\s<)]+)/gi, "$1[$2](https://$2)");
    })
    .join("\n");
}

export async function getStaticPaths() {
  const posts = await getBlogPosts();
  const seenSlugs = new Set();

  return posts
    .map((post) => {
      const normalizedSlug = String(post.slug || "").replace(/^\/+|\/+$/g, "");
      return { ...post, slug: normalizedSlug };
    })
    .filter((post) => post.slug && post.slug !== "#" && !seenSlugs.has(post.slug) && seenSlugs.add(post.slug))
    .map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;

marked.setOptions({
  gfm: true,
  breaks: true
});

const postHtml = marked.parse(autoLinkPlainUrls(post.content || ""));
const normalizedSlug = String(post.slug || "").replace(/^\/+|\/+$/g, "");
const postPath = `/blog/${normalizedSlug}/`;
const postUrl = `https://www.anaghkr.in${postPath}`;

const pageMetadata = {
  title: `${post.title} | Anagh K R Blog`,
  description: post.description,
  keywords: [
    ...(post.tags || []),
    "Anagh K R",
    "Tech Blog",
    "Web Development",
    "Flutter Development",
    "MERN Stack",
    "Kerala Developer"
  ],
  alternates: {
    canonical: postUrl
  },
  openGraph: {
    title: post.title,
    description: post.description,
    type: "article",
    publishedTime: post.date,
    url: postUrl
  },
  twitter: {
    card: "summary_large_image",
    title: post.title,
    description: post.description
  }
};

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  image: post.image ? [post.image] : [],
  author: {
    "@type": "Person",
    name: "Anagh K R",
    url: "https://www.anaghkr.in/"
  },
  publisher: {
    "@type": "Person",
    name: "Anagh K R",
    logo: {
      "@type": "ImageObject",
      url: "https://www.anaghkr.in/favicon.png"
    }
  },
  url: postUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl
  },
  keywords: post.tags ? post.tags.join(", ") : ""
};
---

<BaseLayout metadata={pageMetadata}>
  <article class="min-h-screen pt-24 pb-16 px-4">
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)}></script>

    <div class="max-w-4xl mx-auto">
      <a href="/blog/" class="inline-flex items-center text-gray-400 hover:text-white mb-8 transition-colors">
        Back to Blog
      </a>

      <div class="relative h-[400px] w-full rounded-2xl overflow-hidden mb-8">
        <img
          src={post.image || "https://images.unsplash.com/photo-1499750310159-5b5f87054240?q=80&w=2000&auto=format&fit=crop"}
          alt={post.title}
          class="absolute inset-0 w-full h-full object-cover"
          loading="eager"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"></div>
        <div class="absolute bottom-0 left-0 p-8">
          <div class="flex items-center gap-3 text-sm text-gray-300 mb-4">
            <span>{post.date}</span>
            {post.tags && post.tags.length > 0 && (
              <>
                <span class="w-1 h-1 rounded-full bg-gray-500"></span>
                <span class="px-2 py-1 bg-blue-500/20 text-blue-300 rounded-full text-xs border border-blue-500/30">
                  {post.tags[0]}
                </span>
              </>
            )}
          </div>
          <h1 class="text-3xl md:text-5xl font-bold text-white leading-tight">
            {post.title}
          </h1>
        </div>
      </div>

      <div class="prose prose-invert prose-xl max-w-none text-gray-300 prose-headings:text-white prose-headings:font-bold prose-headings:mb-6 prose-headings:mt-10 prose-p:leading-loose prose-p:mb-8 prose-p:text-gray-300 prose-a:text-blue-400 prose-a:no-underline hover:prose-a:underline prose-strong:text-white prose-strong:font-bold prose-li:marker:text-blue-500 prose-li:mb-2 prose-img:rounded-2xl prose-img:shadow-2xl prose-img:my-10 prose-img:w-full prose-img:object-cover prose-hr:border-gray-800 prose-hr:my-12" set:html={postHtml}></div>
    </div>
  </article>
</BaseLayout>
